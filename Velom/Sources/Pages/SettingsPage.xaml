<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:Velom.Resources.Strings"
             xmlns:services="clr-namespace:Velom.Sources.Services"
             x:Class="Velom.Sources.Pages.SettingsPage"
             Title=""
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" 
              ColumnDefinitions="*,Auto" 
              Padding="15"
              BackgroundColor="#155C5D">
            <Label Grid.Column="0" 
                   Text="{x:Static strings:AppResources.Settings}" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="✖"
                    Clicked="OnCloseButtonClicked"
                    BackgroundColor="#D32F2F"
                    TextColor="White"
                    Padding="15,10"
                    CornerRadius="8"
                    FontAttributes="Bold" />
        </Grid>
        
        <VerticalStackLayout Padding="20" Spacing="20" Grid.Row="1">

            <Frame Padding="15" 
                           Margin="0,8" 
                           BorderColor="#155C5D" 
                           CornerRadius="12"
                           BackgroundColor="White"
                           HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <Label Text="{x:Static strings:AppResources.Language}"
                           FontSize="20" 
                            FontAttributes="Bold"
                            TextColor="#0D3F40"/>

                    <Frame BorderColor="#155C5D"
                           CornerRadius="8"
                           BackgroundColor="#E0F2F2"
                           Padding="5"
                           HasShadow="False">
                        <Picker x:Name="LanguagePicker"
                                Title="{x:Static strings:AppResources.SelectLanguage}"
                                SelectedIndexChanged="OnLanguageChanged"
                                FontSize="20" 
                                FontAttributes="Bold"
                                TextColor="#0D3F40"
                                BackgroundColor="Transparent">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>English</x:String>
                                    <x:String>Français</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                    </Frame>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
        
    </Grid>
    
</ContentPage>
