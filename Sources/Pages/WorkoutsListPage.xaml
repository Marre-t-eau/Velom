<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Velom.Sources.Pages.WorkoutsListPage"
             Title="My Workouts"
             BackgroundColor="#F5F5F5">
    <Grid RowDefinitions="Auto,*">
        <!-- Header with close and new buttons -->
        <Grid Grid.Row="0" 
              ColumnDefinitions="*,Auto,Auto" 
              Padding="15"
              BackgroundColor="#155C5D">
            <Label Grid.Column="0" 
                   Text="My Workouts" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="➕ New"
                    Clicked="OnNewWorkoutClicked"
                    BackgroundColor="#2D8B8E"
                    TextColor="White"
                    Margin="0,0,10,0"
                    Padding="20,10"
                    CornerRadius="8"
                    FontAttributes="Bold" />
            <Button Grid.Column="2"
                    Text="✖"
                    Clicked="OnCloseButtonClicked"
                    BackgroundColor="#D32F2F"
                    TextColor="White"
                    Padding="15,10"
                    CornerRadius="8"
                    FontAttributes="Bold" />
        </Grid>
        
        <!-- Workouts List -->
        <CollectionView Grid.Row="1" 
                        x:Name="WorkoutsCollectionView" 
                        SelectionMode="None"
                        Margin="15">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="#155C5D" 
                           Padding="0" 
                           Margin="0,8"
                           CornerRadius="12"
                           BackgroundColor="White"
                           HasShadow="True">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                            <!-- Top Section: Workout Name and Edit Button -->
                            <Grid Grid.Row="0" 
                                  Grid.ColumnSpan="2"
                                  ColumnDefinitions="*,Auto"
                                  Padding="15,15,15,10"
                                  BackgroundColor="#155C5D">
                                <Label Grid.Column="0" 
                                       Text="{Binding Name}" 
                                       FontSize="20" 
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       VerticalOptions="Center" />
                                
                                <!-- Edit Button - Top Right -->
                                <Button Grid.Column="1"
                                        Text="✏️"
                                        Clicked="OnEditWorkoutClicked"
                                        CommandParameter="{Binding}"
                                        BackgroundColor="#4DB8BA"
                                        TextColor="White"
                                        Padding="12,8"
                                        CornerRadius="8"
                                        FontSize="16"
                                        VerticalOptions="Center" />
                            </Grid>
                            
                            <!-- Workout Info -->
                            <HorizontalStackLayout Grid.Row="1" 
                                                  Grid.ColumnSpan="2"
                                                  Spacing="20"
                                                  Padding="15,15,15,15">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="⏱️" FontSize="16" />
                                    <Label Text="{Binding TotalDurationMinutes, StringFormat='{0} min'}" 
                                           FontSize="15" 
                                           FontAttributes="Bold"
                                           TextColor="#0D3F40" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="💪" FontSize="16" />
                                    <Label Text="{Binding EstimatedTSS, StringFormat='TSS: {0}'}" 
                                           FontSize="15" 
                                           FontAttributes="Bold"
                                           TextColor="#0D3F40" />
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>
                            
                            <!-- Start Button - Full Width -->
                            <Button Grid.Row="2" 
                                    Grid.ColumnSpan="2"
                                    Text="START WORKOUT"
                                    Clicked="OnStartWorkoutClicked"
                                    CommandParameter="{Binding}"
                                    BackgroundColor="#2D8B8E"
                                    TextColor="White"
                                    Padding="0,15"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    CornerRadius="0"
                                    Margin="0" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" 
                                    VerticalOptions="Center"
                                    Spacing="20"
                                    Padding="40">
                    <Label Text="No workouts yet!" 
                           FontSize="28" 
                           FontAttributes="Bold"
                           TextColor="#0D3F40"
                           HorizontalOptions="Center" />
                    <Label Text="Create your first workout to get started" 
                           FontSize="16" 
                           TextColor="#155C5D"
                           HorizontalOptions="Center" />
                    <Button Text="➕ CREATE WORKOUT"
                            Clicked="OnNewWorkoutClicked"
                            BackgroundColor="#27AE60"
                            TextColor="White"
                            HorizontalOptions="Center"
                            Padding="40,15"
                            CornerRadius="8"
                            FontAttributes="Bold" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>