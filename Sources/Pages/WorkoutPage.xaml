<?xml version="1.0" encoding="utf-8" ?>
<pages:BaseBikeControlPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:Velom.Sources.Pages"
             x:Class="Velom.Sources.Pages.WorkoutPage"
             Title="Workout">
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Current Metrics - Fixed at Top -->
        <Frame Grid.Row="0" 
               BorderColor="LightGray" 
               Padding="10" 
               CornerRadius="10"
               Margin="10,0,10,10"
               HasShadow="True">
            <VerticalStackLayout Spacing="10">
                
                <!-- Timer and Progress Info -->
                <Grid ColumnDefinitions="*,Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10">
                    <!-- Left: Block Progress -->
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Start">
                        <Label x:Name="BlockProgressLabel" 
                               Text="Block 0/0" 
                               FontSize="Small"
                               FontAttributes="Bold"
                               TextColor="Purple" />
                        <Label x:Name="TotalTimeLabel" 
                               Text="Total: 0:00" 
                               FontSize="Micro"
                               TextColor="Gray" />
                    </VerticalStackLayout>
                    
                    <!-- Center: Timer -->
                    <Label Grid.Column="1"
                           x:Name="TimerLabel" 
                           Text="00:00:00" 
                           FontSize="Large" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center" 
                           TextColor="White" />
                    
                    <!-- Right: Time Remaining -->
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="End">
                        <Label x:Name="TimeRemainingLabel" 
                               Text="Remaining:" 
                               FontSize="Small"
                               FontAttributes="Bold"
                               TextColor="OrangeRed"
                               HorizontalTextAlignment="End" />
                        <Label x:Name="TimeRemainingValueLabel" 
                               Text="0:00" 
                               FontSize="Small"
                               TextColor="OrangeRed"
                               HorizontalTextAlignment="End" />
                    </VerticalStackLayout>
                </Grid>
                
                <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                    <Label Grid.Row="0" Grid.Column="0" Text="Power:" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Grid.Row="1" Grid.Column="0" x:Name="PowerView" Text="N/A" HorizontalTextAlignment="Center" FontSize="Large" />
                    
                    <Label Grid.Row="0" Grid.Column="1" Text="Cadence:" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Grid.Row="1" Grid.Column="1" x:Name="CadenceView" Text="N/A" HorizontalTextAlignment="Center" FontSize="Large" />
                    
                    <Label Grid.Row="0" Grid.Column="2" Text="Heart Rate:" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Grid.Row="1" Grid.Column="2" x:Name="HeartRateView" Text="N/A" HorizontalTextAlignment="Center" FontSize="Large" />
                </Grid>
                
                <!-- Targets in a compact row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                    <HorizontalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="5">
                        <Label Text="🎯" />
                        <Label x:Name="TargetPowerView" Text="0 W" FontAttributes="Bold" TextColor="DodgerBlue" />
                    </HorizontalStackLayout>
                    
                    <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="5">
                        <Label Text="🔄" />
                        <Label x:Name="TargetCadenceView" Text="0 rpm" FontAttributes="Bold" TextColor="Green" />
                    </HorizontalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Frame>
        
        <!-- Scrollable Workout Blocks -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="10,0,10,10">
            
            <CollectionView Grid.Row="1" 
                            x:Name="WorkBlocksCollectionView" 
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="{Binding BorderColor}" 
                               Padding="8" 
                               Margin="2,3"
                               CornerRadius="5"
                               BackgroundColor="{Binding BackgroundColor}"
                               Opacity="{Binding BlockOpacity}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <!-- Left: Emoji indicators -->
                                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                    <Label Text="💪" FontSize="Small" IsVisible="{Binding AsTargetPower}" />
                                    <Label Text="🔄" FontSize="Small" IsVisible="{Binding AsTargetedCadence}" />
                                </VerticalStackLayout>
                                
                                <!-- Center: Target info -->
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <!-- Power Target -->
                                    <Label IsVisible="{Binding IsRamp}"
                                           FontSize="Small"
                                           FontAttributes="Bold"
                                           TextColor="DarkOrange">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}Ramp {0}W → {1}W">
                                                <Binding Path="TargetPowerStartString" />
                                                <Binding Path="TargetPowerEndString" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Label IsVisible="{Binding IsConstant}" 
                                           Text="{Binding TargetPowerString, StringFormat='{}{0}W'}"
                                           FontSize="Small"
                                           FontAttributes="Bold"
                                           TextColor="DodgerBlue" />
                                    <Label IsVisible="{Binding AsNoTargetPower}" 
                                           Text="Free power"
                                           FontSize="Small"
                                           FontAttributes="Italic"
                                           TextColor="Gray" />
                                    
                                    <!-- Cadence Target -->
                                    <Label IsVisible="{Binding AsTargetedCadence}" 
                                           Text="{Binding TargetCadenceString, StringFormat='{}{0} rpm'}"
                                           FontSize="Small"
                                           TextColor="Green" />
                                </VerticalStackLayout>
                                
                                <!-- Right: Time Progress -->
                                <Label Grid.Column="2" 
                                       FontSize="Small"
                                       FontAttributes="Bold" 
                                       TextColor="Gray"
                                       VerticalOptions="Center">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0}/{1}s">
                                            <Binding Path="TimeDoneString" />
                                            <Binding Path="DurationString" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="🎉 No blocks to do, enjoy your easy day!"
                           FontSize="Small"
                           HorizontalOptions="Center"
                           Margin="10" />
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>
        
        <!-- Bottom Control Buttons - Fixed at Bottom -->
        <Frame Grid.Row="2" 
               BorderColor="Green" 
               Padding="10" 
               CornerRadius="10"
               Margin="10,0,10,0"
               HasShadow="True">
            <VerticalStackLayout Spacing="10">
                <!-- Start Button -->
                <Button x:Name="StartButton"
                        Text="Start Workout"
                        Clicked="OnStartButtonClicked"
                        BackgroundColor="Green"
                        TextColor="White"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        IsVisible="True" />
                
                <!-- Pause and Stop Buttons (initially hidden) -->
                <HorizontalStackLayout x:Name="PauseStopButtons" 
                                      Spacing="10" 
                                      HorizontalOptions="Center"
                                      IsVisible="False">
                    <Button x:Name="PauseButton"
                            Text="Pause"
                            Clicked="OnPauseButtonClicked"
                            BackgroundColor="Orange"
                            TextColor="White"
                            FontAttributes="Bold"
                            WidthRequest="150"
                            HeightRequest="50" />
                    
                    <Button x:Name="StopButton"
                            Text="Stop"
                            Clicked="OnStopButtonClicked"
                            BackgroundColor="Red"
                            TextColor="White"
                            FontAttributes="Bold"
                            WidthRequest="150"
                            HeightRequest="50" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>
    </Grid>
</pages:BaseBikeControlPage>