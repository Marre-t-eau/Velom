<?xml version="1.0" encoding="utf-8" ?>
<pages:BaseBikeControlPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:Velom.Sources.Pages"
             x:Class="Velom.Sources.Pages.ControlPage"
             Title=""
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F5F5F5">
    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" 
              ColumnDefinitions="*,Auto" 
              Padding="15"
              BackgroundColor="#155C5D">
            <Label Grid.Column="0" 
                   Text="Manual Control" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"
                   HorizontalOptions="Start" />
            <Button Grid.Column="1"
                    Text="✖"
                    Clicked="OnCloseClicked"
                    BackgroundColor="#D32F2F"
                    TextColor="White"
                    Padding="12,8"
                    WidthRequest="45"
                    HeightRequest="45"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    FontSize="18" />
        </Grid>
        
        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="15">
            
            <Frame BorderColor="#155C5D" Padding="15" CornerRadius="12" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="TimerLabel" 
                           Text="00:00:00" 
                           FontSize="28" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center" 
                           TextColor="#155C5D"
                           Margin="0,5,0,10" />
                    
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="15" RowSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Text="Power:" FontAttributes="Bold" TextColor="#0D3F40" FontSize="16" />
                        <Label Grid.Row="0" Grid.Column="1" x:Name="PowerLabel" Text="N/A" TextColor="#155C5D" FontSize="16" FontAttributes="Bold" />
                        
                        <Label Grid.Row="1" Grid.Column="0" Text="Cadence:" FontAttributes="Bold" TextColor="#0D3F40" FontSize="16" />
                        <Label Grid.Row="1" Grid.Column="1" x:Name="CadenceLabel" Text="N/A" TextColor="#155C5D" FontSize="16" FontAttributes="Bold" />
                        
                        <Label Grid.Row="2" Grid.Column="0" Text="Heart Rate:" FontAttributes="Bold" TextColor="#0D3F40" FontSize="16" />
                        <Label Grid.Row="2" Grid.Column="1" x:Name="HeartRateLabel" Text="N/A" TextColor="#155C5D" FontSize="16" FontAttributes="Bold" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Session Control Buttons -->
            <Frame BorderColor="#155C5D" Padding="15" CornerRadius="12" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <!-- Start Button -->
                    <Button x:Name="StartButton"
                            Text="Start Session"
                            Clicked="OnStartButtonClicked"
                            BackgroundColor="#2D8B8E"
                            TextColor="White"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="8"
                            IsVisible="True" />
                    
                    <!-- Pause and Stop Buttons (initially hidden) -->
                    <HorizontalStackLayout x:Name="PauseStopButtons" 
                                          Spacing="10" 
                                          HorizontalOptions="Center"
                                          IsVisible="False">
                        <Button x:Name="PauseButton"
                                Text="Pause"
                                Clicked="OnPauseButtonClicked"
                                BackgroundColor="#4DB8BA"
                                TextColor="White"
                                FontAttributes="Bold"
                                WidthRequest="120"
                                HeightRequest="50"
                                CornerRadius="8" />
                        
                    <Button x:Name="StopButton"
                            Text="Stop"
                            Clicked="OnStopButtonClicked"
                            BackgroundColor="#D32F2F"
                                TextColor="White"
                                FontAttributes="Bold"
                                WidthRequest="120"
                                HeightRequest="50"
                                CornerRadius="8" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#155C5D" Padding="15" CornerRadius="12" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <VerticalStackLayout Spacing="10" x:Name="PowerControlSection" IsEnabled="False">
                        <Label Text="Target Power (W)" 
                               FontSize="18" 
                               HorizontalOptions="Center"
                               TextColor="#155C5D"
                               FontAttributes="Bold" />
                        
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Button Text="-5" 
                                    Clicked="OnDecrease5Power" 
                                    WidthRequest="60"
                                    BackgroundColor="#4DB8BA"
                                    TextColor="White"
                                    CornerRadius="8" />
                            <Entry x:Name="TargetPowerEntry" 
                                   Text="100" 
                                   Placeholder="Enter power" 
                                   Keyboard="Numeric" 
                                   TextChanged="OnTargetPowerChanged"
                                   WidthRequest="100"
                                   HorizontalTextAlignment="Center"
                                   BackgroundColor="#E0F2F2"
                                   TextColor="#0D3F40"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                            <Button Text="+5" 
                                    Clicked="OnIncrease5Power" 
                                    WidthRequest="60"
                                    BackgroundColor="#4DB8BA"
                                    TextColor="White"
                                    CornerRadius="8" />
                        </HorizontalStackLayout>

                        <Label Text="Quick Presets" 
                               FontSize="16" 
                               HorizontalOptions="Center" 
                               Margin="0,10,0,0"
                               TextColor="#0D3F40"
                               FontAttributes="Bold" />
                        <FlexLayout Wrap="Wrap" 
                                    JustifyContent="Center" 
                                    AlignItems="Center">
                            <Button Text="50W" Clicked="OnPreset50" Margin="5" BackgroundColor="#155C5D" TextColor="White" CornerRadius="8" />
                            <Button Text="100W" Clicked="OnPreset100" Margin="5" BackgroundColor="#155C5D" TextColor="White" CornerRadius="8" />
                            <Button Text="150W" Clicked="OnPreset150" Margin="5" BackgroundColor="#155C5D" TextColor="White" CornerRadius="8" />
                            <Button Text="200W" Clicked="OnPreset200" Margin="5" BackgroundColor="#155C5D" TextColor="White" CornerRadius="8" />
                            <Button Text="250W" Clicked="OnPreset250" Margin="5" BackgroundColor="#155C5D" TextColor="White" CornerRadius="8" />
                            <Button Text="300W" Clicked="OnPreset300" Margin="5" BackgroundColor="#155C5D" TextColor="White" CornerRadius="8" />
                        </FlexLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
    </Grid>
</pages:BaseBikeControlPage>
