<?xml version="1.0" encoding="utf-8" ?>
<pages:BaseBikeControlPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:Velom.Sources.Pages"
             x:Class="Velom.Sources.Pages.ControlPage"
             Title="Manual Control">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            
            <Frame BorderColor="LightGray" Padding="10" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Current Metrics" 
                           FontSize="Title" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center" />
                    
                    <Label x:Name="TimerLabel" 
                           Text="00:00:00" 
                           FontSize="Large" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center" 
                           TextColor="Blue"
                           Margin="0,5,0,10" />
                    
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                        <Label Grid.Row="0" Grid.Column="0" Text="Power:" FontAttributes="Bold" />
                        <Label Grid.Row="0" Grid.Column="1" x:Name="PowerLabel" Text="N/A" />
                        
                        <Label Grid.Row="1" Grid.Column="0" Text="Cadence:" FontAttributes="Bold" />
                        <Label Grid.Row="1" Grid.Column="1" x:Name="CadenceLabel" Text="N/A" />
                        
                        <Label Grid.Row="2" Grid.Column="0" Text="Heart Rate:" FontAttributes="Bold" />
                        <Label Grid.Row="2" Grid.Column="1" x:Name="HeartRateLabel" Text="N/A" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Session Control Buttons -->
            <Frame BorderColor="Green" Padding="10" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Session Control" 
                           FontSize="Title" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center" />
                    
                    <!-- Start Button -->
                    <Button x:Name="StartButton"
                            Text="Start Session"
                            Clicked="OnStartButtonClicked"
                            BackgroundColor="Green"
                            TextColor="White"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            IsVisible="True" />
                    
                    <!-- Pause and Stop Buttons (initially hidden) -->
                    <HorizontalStackLayout x:Name="PauseStopButtons" 
                                          Spacing="10" 
                                          HorizontalOptions="Center"
                                          IsVisible="False">
                        <Button x:Name="PauseButton"
                                Text="Pause"
                                Clicked="OnPauseButtonClicked"
                                BackgroundColor="Orange"
                                TextColor="White"
                                FontAttributes="Bold"
                                WidthRequest="150"
                                HeightRequest="50" />
                        
                        <Button x:Name="StopButton"
                                Text="Stop"
                                Clicked="OnStopButtonClicked"
                                BackgroundColor="Red"
                                TextColor="White"
                                FontAttributes="Bold"
                                WidthRequest="150"
                                HeightRequest="50" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="LightBlue" Padding="10" CornerRadius="10">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Power Control" 
                           FontSize="Title" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center" />

                    <VerticalStackLayout Spacing="10" x:Name="PowerControlSection" IsEnabled="False">
                        <Label Text="Target Power (W)" 
                               FontSize="Medium" 
                               HorizontalOptions="Center" />
                        
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Button Text="-5" 
                                    Clicked="OnDecrease5Power" 
                                    WidthRequest="60" />
                            <Entry x:Name="TargetPowerEntry" 
                                   Text="100" 
                                   Placeholder="Enter power" 
                                   Keyboard="Numeric" 
                                   TextChanged="OnTargetPowerChanged"
                                   WidthRequest="100"
                                   HorizontalTextAlignment="Center" />
                            <Button Text="+5" 
                                    Clicked="OnIncrease5Power" 
                                    WidthRequest="60" />
                        </HorizontalStackLayout>

                        <Label Text="Quick Presets" 
                               FontSize="Small" 
                               HorizontalOptions="Center" 
                               Margin="0,10,0,0" />
                        <FlexLayout Wrap="Wrap" 
                                    JustifyContent="Center" 
                                    AlignItems="Center">
                            <Button Text="50W" Clicked="OnPreset50" Margin="5" />
                            <Button Text="100W" Clicked="OnPreset100" Margin="5" />
                            <Button Text="150W" Clicked="OnPreset150" Margin="5" />
                            <Button Text="200W" Clicked="OnPreset200" Margin="5" />
                            <Button Text="250W" Clicked="OnPreset250" Margin="5" />
                            <Button Text="300W" Clicked="OnPreset300" Margin="5" />
                        </FlexLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Button Text="Close" 
                    Clicked="OnCloseClicked" 
                    BackgroundColor="Gray"
                    TextColor="White"
                    Margin="0,20,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</pages:BaseBikeControlPage>
