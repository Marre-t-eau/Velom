<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Velom.Sources.Pages.WorkoutHistoryPage"
             Title=""
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F5F5F5">
    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" 
              ColumnDefinitions="*,Auto" 
              Padding="15"
              BackgroundColor="#155C5D">
            <Label Grid.Column="0" 
                   Text="📊 Workout History" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="✖"
                    Clicked="OnCloseButtonClicked"
                    BackgroundColor="#D32F2F"
                    TextColor="White"
                    Padding="15,10"
                    CornerRadius="8"
                    FontAttributes="Bold" />
        </Grid>
        
        <!-- History List -->
        <CollectionView Grid.Row="1"
                        x:Name="HistoryCollectionView" 
                        SelectionMode="None"
                        Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="15" 
                           Margin="5" 
                           BorderColor="#155C5D" 
                           CornerRadius="12"
                           BackgroundColor="White"
                           HasShadow="True">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnWorkoutTapped"/>
                        </Frame.GestureRecognizers>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.ColumnSpan="2"
                                   Text="{Binding WorkoutName}" 
                                   FontSize="20" 
                                   FontAttributes="Bold"
                                   TextColor="#0D3F40" />
                            
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding StartTime, StringFormat='📅 {0:dd/MM/yyyy HH:mm}'}" 
                                   FontSize="14"
                                   TextColor="#155C5D" />
                            
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding FormattedDuration}" 
                                   FontSize="14"
                                   TextColor="#155C5D"
                                   HorizontalOptions="End" />
                            
                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="{Binding AveragePower, StringFormat='⚡ Avg: {0:F0}W'}" 
                                   FontSize="14"
                                   TextColor="#2D8B8E"
                                   FontAttributes="Bold" />
                            
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding MaxPower, StringFormat='Max: {0}W'}" 
                                   FontSize="14"
                                   TextColor="#2D8B8E"
                                   FontAttributes="Bold"
                                   HorizontalOptions="End" />
                            
                            <Label Grid.Row="3" Grid.Column="0"
                                   Text="{Binding TSS, StringFormat='TSS: {0:F0}'}" 
                                   FontSize="14" 
                                   FontAttributes="Bold"
                                   TextColor="#4DB8BA" />
                            
                            <Label Grid.Row="3" Grid.Column="1"
                                   Text="{Binding TotalKilojoules, StringFormat='⚡ {0:F0} kJ'}" 
                                   FontSize="14"
                                   TextColor="#4DB8BA"
                                   FontAttributes="Bold"
                                   HorizontalOptions="End" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <StackLayout Padding="20" VerticalOptions="Center">
                    <Label Text="📊 No workout history yet" 
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" 
                           TextColor="#0D3F40" />
                    <Label Text="Complete a workout to see it here!" 
                           FontSize="16"
                           HorizontalOptions="Center" 
                           TextColor="#7F8C8D" 
                           Margin="0,10,0,0" />
                </StackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
