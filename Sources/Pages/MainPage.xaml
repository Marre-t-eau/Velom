<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Velom.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="20">
            <Button Text="Scan for Devices" Clicked="ScanButton_Clicked" />
            <ListView x:Name="DevicesListView">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextCell Text="{Binding Name}" Detail="{Binding Id}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Label x:Name="PowerLabel" Text="Power: N/A" FontSize="Large" HorizontalOptions="Center" />
            <Label x:Name="CadenceLabel" Text="Cadence: N/A" FontSize="Large" HorizontalOptions="Center" />
            <Label x:Name="HeartRateLabel" Text="Heart rate: N/A" FontSize="Large" HorizontalOptions="Center" />
            
            <Button Text="🎛️ Manual Control" 
                    Clicked="OnManualControlClicked"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    Margin="0,10,0,0" />
            
            <Button Text="See workouts" Clicked="OnViewWorkoutsClicked" />
            <Button Text="📊 Workout History" 
                    Clicked="OnViewHistoryClicked"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    Margin="0,10,0,0" />
            <HorizontalStackLayout>
                <Label Text="FTP :" VerticalOptions="Center"></Label>
                <Entry x:Name="FTP" VerticalOptions="Center" Placeholder="Enter FTP" Keyboard="Numeric" />
                <Button Text="Ok" Clicked="SetNewFTP_Clicked"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
