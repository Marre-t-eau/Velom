<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Velom.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="20">
            <Button Text="Scan for Devices" Clicked="ScanButton_Clicked" />
            <ListView x:Name="DevicesListView">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextCell Text="{Binding Name}" Detail="{Binding Id}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Label x:Name="PowerLabel" Text="Power: N/A" FontSize="Large" HorizontalOptions="Center" />
            <Label x:Name="CadenceLabel" Text="Cadence: N/A" FontSize="Large" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
